# Haute - Databricks credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# However be wary that some coding agents have access to .env files
#
#   cp .env.example .env

# ── Data workspace (reading Unity Catalog tables) ─────────────────
# Databricks workspace URL (no trailing slash)
DATABRICKS_HOST=https://adb-1234567890123456.12.azuredatabricks.net

# Personal access token (Databricks → User Settings → Developer → Access Tokens)
DATABRICKS_TOKEN=your_databricks_token_here

# ── Deploy workspace (Model Serving) ─────────────────────────────
# If your serving endpoint lives in the same workspace as your data,
# leave these blank — the credentials above will be used automatically.
DATABRICKS_RATING_HOST=
DATABRICKS_RATING_TOKEN=
