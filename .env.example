# Haute - Databricks credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# However be wary that some coding agents have acces to .env files
#
#   cp .env.example .env

# ── Deploy workspace (Model Serving) ──────────────────────────────
# Databricks workspace URL (no trailing slash)
DATABRICKS_HOST=https://adb-1234567890123456.12.azuredatabricks.net

# Personal access token (Databricks → User Settings → Developer → Access Tokens)
DATABRICKS_TOKEN=your_databricks_token_here

# ── Data workspace (reading Unity Catalog tables) ────────────────
# If your data lives in the same workspace as deploy, leave these
# blank — the deploy credentials above will be used automatically.
# The SQL Warehouse HTTP path is set on each data source node in the
# pipeline (not here), but you can set a fallback default below.
DATABRICKS_DATA_HOST=
DATABRICKS_DATA_TOKEN=


